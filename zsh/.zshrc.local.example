# 机器专属配置 — 复制为 ~/.zshrc.local，按实际情况修改
# 此文件不会被 stow 同步，需手动拷贝到 $HOME

# ── PATH ────────────────────────────────────────────────────────────────────
# export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
# export PATH="/opt/homebrew/lib/ruby/gems/3.x.0/bin:$PATH"
# export PATH="$PATH:$HOME/.dotnet/tools"

# ── 环境变量 ─────────────────────────────────────────────────────────────────
# export DOTNET_ROOT=/usr/local/share/dotnet
# export BARK_KEY="your-bark-key-here"

# ── 代理 ─────────────────────────────────────────────────────────────────────
# export https_proxy=http://127.0.0.1:7897
# export http_proxy=http://127.0.0.1:7897
# export all_proxy=socks5://127.0.0.1:7897
# export no_proxy=localhost,127.0.0.1,*.local

# alias pon="source ~/proxy_control.sh on"
# alias poff="source ~/proxy_control.sh off"
# alias pst="~/proxy_control.sh status"
# alias ptest="~/proxy_control.sh test"

# ── 工具 alias ───────────────────────────────────────────────────────────────
# alias dotnet-ef='$HOME/.dotnet/tools/dotnet-ef'

# ── 自定义函数 ────────────────────────────────────────────────────────────────
# pm() {
#   node /path/to/pm/product-pm2.js "$@"
# }
